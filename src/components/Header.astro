---
import { SITE_TITLE } from '../consts';
import { getSiteSettings } from '../lib/content';

const settings = await getSiteSettings();
const navigation = settings.navigation.length
  ? settings.navigation
  : [{ label: 'Kontaktai', href: '/kontaktai' }];
---

<header class="site-header">
  <nav class="page-shell header-nav" aria-label="Pagrindinė navigacija">
    <a href="/" class="brand">
      <span class="brand-mark" aria-hidden="true">EE</span>
      <span class="brand-copy">
        <strong>{SITE_TITLE}</strong>
        <span>Lietuviams tarp JK ir Lietuvos</span>
      </span>
    </a>

    <div class="menu-backdrop"></div>

    <div class="nav-wrapper">
      <div class="internal-links">
        {navigation.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>

      <div class="mobile-social-links">
        <a href="/kontaktai" title="Kontaktai" class="action-icon">
          <span class="sr-only">Kontaktai</span>
          <svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24">
            <path fill="currentColor" d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"></path>
          </svg>
        </a>
        <a href={settings.facebookGroupUrl} target="_blank" rel="noopener noreferrer" class="action-icon">
          <span class="sr-only">Facebook grupė</span>
          <svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24">
            <path fill="currentColor" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="desktop-actions">
      <a href="/kontaktai" title="Kontaktai" class="action-icon">
        <span class="sr-only">Kontaktai</span>
        <svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
          <path fill="currentColor" d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"></path>
        </svg>
      </a>
      <a href={settings.facebookGroupUrl} target="_blank" rel="noopener noreferrer" class="action-icon">
        <span class="sr-only">Facebook grupė</span>
        <svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
          <path fill="currentColor" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path>
        </svg>
      </a>
    </div>

    <button class="mobile-menu-toggle" aria-label="Atidaryti meniu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
</header>

<script>
  const toggle = document.querySelector('.mobile-menu-toggle');
  const nav = document.querySelector('.nav-wrapper');
  const backdrop = document.querySelector('.menu-backdrop');

  function closeMenu() {
    toggle?.classList.remove('active');
    nav?.classList.remove('active');
    backdrop?.classList.remove('active');
  }

  toggle?.addEventListener('click', () => {
    toggle.classList.toggle('active');
    nav?.classList.toggle('active');
    backdrop?.classList.toggle('active');
  });

  backdrop?.addEventListener('click', closeMenu);

  document.querySelectorAll('.internal-links a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 1rem 0 0;
  }

  .header-nav {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 251, 245, 0.82);
    box-shadow: 0 16px 45px rgba(39, 31, 23, 0.08);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
    min-width: 0;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.45rem;
    height: 2.45rem;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(184, 100, 50, 0.14), rgba(111, 125, 103, 0.12));
    border: 1px solid rgba(97, 78, 57, 0.12);
    color: var(--surface-ink);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45);
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .brand-copy strong {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--surface-ink);
  }

  .brand-copy span {
    font-size: 0.78rem;
    color: var(--text-faint);
  }

  .nav-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    min-width: 0;
  }

  .internal-links {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.3rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(97, 78, 57, 0.1);
  }

  .internal-links a {
    padding: 0.78rem 1rem;
    border-radius: 999px;
    color: var(--text-soft);
    font-size: 0.97rem;
    font-weight: 700;
    text-decoration: none;
    transition: background-color 0.25s ease, color 0.25s ease, transform 0.25s ease;
  }

  .internal-links a:hover {
    background: rgba(255, 247, 238, 0.9);
    color: var(--accent-deep);
    transform: translateY(-1px);
  }

  .desktop-actions,
  .mobile-social-links {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .action-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.56);
    border: 1px solid rgba(97, 78, 57, 0.1);
    color: var(--surface-ink);
    text-decoration: none;
    transition: background-color 0.25s ease, color 0.25s ease, transform 0.25s ease;
  }

  .action-icon:hover {
    background: rgba(255, 247, 238, 0.94);
    color: var(--accent-deep);
    transform: translateY(-1px);
  }

  .mobile-social-links,
  .mobile-menu-toggle,
  .menu-backdrop {
    display: none;
  }

  .mobile-menu-toggle {
    flex-direction: column;
    gap: 4px;
    width: 2.8rem;
    height: 2.8rem;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(97, 78, 57, 0.12);
    border-radius: 999px;
    cursor: pointer;
  }

  .mobile-menu-toggle span {
    width: 17px;
    height: 2px;
    border-radius: 999px;
    background: var(--surface-ink);
    transition: all 0.25s ease;
  }

  .mobile-menu-toggle.active span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .mobile-menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-toggle.active span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (max-width: 860px) {
    .site-header {
      padding-top: 0.8rem;
    }

    .header-nav {
      grid-template-columns: 1fr auto;
      padding: 0.95rem 1rem;
    }

    .desktop-actions {
      display: none;
    }

    .mobile-menu-toggle,
    .menu-backdrop {
      display: flex;
    }

    .brand-copy span {
      display: none;
    }

    .nav-wrapper {
      position: fixed;
      top: 1rem;
      right: -100%;
      width: min(82vw, 320px);
      height: calc(100vh - 2rem);
      padding: 5.7rem 1.2rem 1.2rem;
      flex-direction: column;
      justify-content: flex-start;
      align-items: stretch;
      gap: 1rem;
      border-radius: 2rem;
      background: rgba(255, 251, 245, 0.98);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      backdrop-filter: blur(20px);
      transition: right 0.28s ease;
      z-index: 60;
    }

    .nav-wrapper.active {
      right: 1rem;
    }

    .menu-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(13, 18, 26, 0.26);
      backdrop-filter: blur(3px);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.25s ease, visibility 0.25s ease;
      z-index: 55;
    }

    .menu-backdrop.active {
      opacity: 1;
      visibility: visible;
    }

    .internal-links {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0.2rem;
      padding: 0.4rem;
      border-radius: 1.4rem;
    }

    .internal-links a {
      padding: 1rem;
      border-radius: 1rem;
    }

    .mobile-social-links {
      display: flex;
      margin-top: auto;
      padding-top: 0.5rem;
      justify-content: flex-start;
    }
  }
</style>
