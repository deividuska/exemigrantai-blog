---
import { getSiteSettings } from '../lib/content';

const today = new Date();
const settings = await getSiteSettings();
---

<footer class="site-footer">
  <div class="page-shell footer-shell">
    <div>
      <p class="footer-label">Eks Emigrantai</p>
      <p class="footer-copy">&copy; {today.getFullYear()} {settings.footerText}</p>
      <div class="footer-links">
        <a href="/apie-mus" class="footer-text-link">Apie mus</a>
        <a href="/redakcine-politika" class="footer-text-link">Redakcinė politika</a>
        <a href="/kontaktai" class="footer-text-link">Kontaktai</a>
        <a href="/privatumo-politika" class="footer-text-link">Privatumo politika</a>
      </div>
    </div>

    <div class="footer-actions">
      <a href={settings.facebookGroupUrl} target="_blank" rel="noopener noreferrer" class="footer-link">
        Prisijunkite prie Facebook grupės
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 3.5rem 0 4rem;
  }

  .footer-shell {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    padding: 1.6rem 1.8rem;
    border-top: 1px solid var(--border-strong);
    color: var(--text-soft);
  }

  .footer-label,
  .footer-copy {
    margin: 0;
  }

  .footer-label {
    color: var(--surface-ink);
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .footer-copy {
    margin-top: 0.35rem;
    font-size: 0.94rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 0.85rem;
  }

  .footer-text-link {
    color: var(--accent-deep);
    font-weight: 700;
    text-decoration: none;
  }

  .footer-text-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.85rem 1.15rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(97, 78, 57, 0.12);
    color: var(--surface-ink);
    text-decoration: none;
    font-weight: 700;
    transition: transform 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }

  .footer-link::after {
    content: '↗';
    font-size: 0.94rem;
  }

  .footer-link:hover {
    transform: translateY(-1px);
    color: var(--accent-deep);
    border-color: rgba(184, 100, 50, 0.24);
  }

  @media (max-width: 768px) {
    .site-footer {
      padding: 2.8rem 0 3.2rem;
    }

    .footer-shell {
      flex-direction: column;
      align-items: flex-start;
      padding: 1.2rem 0 0;
    }
  }
</style>
