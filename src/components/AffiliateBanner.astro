---
type AffiliateAd = {
  enabled?: boolean;
  label?: string;
  title?: string;
  description?: string;
  cta?: string;
  url?: string;
  disclosure?: string;
  image?: string;
  imageAlt?: string;
  placements?: {
    top?: boolean;
    middle?: boolean;
    bottom?: boolean;
  };
};

type Placement = 'top' | 'middle' | 'bottom';

const {
  ad,
  placement,
  compact = false,
} = Astro.props as {
  ad?: AffiliateAd;
  placement: Placement;
  compact?: boolean;
};

const isEnabled =
  ad?.enabled &&
  ad.url &&
  ad.title &&
  ad.description &&
  ad.placements?.[placement] !== false;
---

{
  isEnabled && (
    <aside class:list={['affiliate-banner', `affiliate-banner-${placement}`, { compact }]}>
      <div class="affiliate-copy">
        <p class="affiliate-label">{ad.label || 'Partnerio nuoroda'}</p>
        <h2>{ad.title}</h2>
        <p>{ad.description}</p>
        {ad.disclosure && <p class="affiliate-disclosure">{ad.disclosure}</p>}
      </div>

      {ad.image && (
        <div class="affiliate-media" aria-hidden={!ad.imageAlt}>
          <img src={ad.image} alt={ad.imageAlt || ''} loading="lazy" />
        </div>
      )}

      <a href={ad.url} target="_blank" rel="sponsored noopener noreferrer" class="affiliate-cta">
        {ad.cta || 'Sužinoti daugiau'}
      </a>
    </aside>
  )
}

<style>
  .affiliate-banner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    margin: 1.7rem auto;
    padding: 1rem;
    max-width: 72ch;
    border: 1px solid rgba(184, 100, 50, 0.22);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(135deg, rgba(255, 253, 250, 0.96), rgba(247, 240, 229, 0.9)),
      radial-gradient(circle at top right, rgba(111, 125, 103, 0.12), transparent 16rem);
    box-shadow: var(--shadow-soft);
  }

  .affiliate-banner-top {
    margin-top: 0;
  }

  .affiliate-copy {
    min-width: 0;
  }

  .affiliate-label,
  .affiliate-copy h2,
  .affiliate-copy p {
    margin: 0;
  }

  .affiliate-label {
    color: var(--accent-deep);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .affiliate-copy h2 {
    margin-top: 0.35rem;
    color: var(--surface-ink);
    font-family: var(--font-serif);
    font-size: 1.45rem;
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .affiliate-copy p {
    margin-top: 0.5rem;
    color: var(--text-soft);
    font-size: 0.98rem;
    line-height: 1.65;
  }

  .affiliate-copy .affiliate-disclosure {
    color: var(--text-faint);
    font-size: 0.82rem;
    line-height: 1.55;
  }

  .affiliate-media {
    grid-row: span 2;
    width: 6.5rem;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: calc(var(--radius-md) - 4px);
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid var(--border);
  }

  .affiliate-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .affiliate-cta {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.78rem 1rem;
    border-radius: 999px;
    background: var(--surface-ink);
    color: #fffaf4;
    font-size: 0.93rem;
    font-weight: 800;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .affiliate-cta:hover {
    transform: translateY(-1px);
    background: #22304a;
  }

  .compact {
    padding: 0.95rem;
  }

  @media (max-width: 720px) {
    .affiliate-banner {
      grid-template-columns: 1fr;
      gap: 0.9rem;
      margin: 1.4rem auto;
      padding: 1rem;
    }

    .affiliate-media {
      width: 100%;
      max-width: 12rem;
      aspect-ratio: 16 / 9;
      grid-row: auto;
    }

    .affiliate-cta {
      justify-self: stretch;
      white-space: normal;
      text-align: center;
    }
  }
</style>
