---
import { Image } from 'astro:assets';
import type { PostEntry } from '../lib/content';
import { formatLithuanianDate, getPostExcerpt } from '../lib/content';

interface Props {
  post: PostEntry;
  eager?: boolean;
}

const { post, eager = false } = Astro.props;
const category = post.data.category?.trim();
const imageAlt = post.data.featuredImageAlt || post.data.title;
const excerpt = getPostExcerpt(post);
---

<article class="post-card">
  {post.data.featuredImage && (
    <a href={`/blog/${post.slug}/`} class="post-card-media">
      <Image
        src={post.data.featuredImage}
        alt={imageAlt}
        class="post-card-image"
        loading={eager ? 'eager' : 'lazy'}
        fetchpriority={eager ? 'high' : 'auto'}
        quality={65}
        widths={[320, 480, 640, 736]}
        sizes="(min-width: 1024px) 368px, (min-width: 640px) calc((100vw - 3.5rem) / 2), calc(100vw - 2rem)"
      />
    </a>
  )}

  <div class="post-card-body">
    <div class="post-card-meta">
      {category && <span class="post-card-category">{category}</span>}
      <time class="post-card-date">{formatLithuanianDate(post.data.publishedAt)}</time>
    </div>

    <h2 class="post-card-title">
      <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
    </h2>

    <p class="post-card-excerpt">{excerpt}</p>

    <a href={`/blog/${post.slug}/`} class="post-card-link">
      Skaityti daugiau
      <span aria-hidden="true">→</span>
    </a>
  </div>
</article>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: rgba(255, 252, 247, 0.92);
    box-shadow: var(--shadow-soft);
    transition: transform 0.28s ease, border-color 0.28s ease, box-shadow 0.28s ease;
  }

  .post-card:hover {
    transform: translateY(-4px);
    border-color: rgba(184, 100, 50, 0.22);
    box-shadow: 0 22px 46px rgba(45, 35, 26, 0.1);
  }

  .post-card-media {
    display: block;
    position: relative;
    overflow: hidden;
    aspect-ratio: 1.25;
    background: rgba(22, 32, 51, 0.04);
  }

  .post-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .post-card:hover .post-card-image {
    transform: scale(1.03);
  }

  .post-card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 1rem;
    padding: 1.35rem 1.35rem 1.45rem;
  }

  .post-card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem;
  }

  .post-card-category {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    background: rgba(184, 100, 50, 0.12);
    color: var(--accent-deep);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .post-card-date {
    color: var(--text-faint);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .post-card-title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.65rem;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--surface-ink);
    text-wrap: balance;
  }

  .post-card-title a {
    text-decoration: none;
  }

  .post-card-excerpt {
    margin: 0;
    color: var(--text-soft);
    font-size: 1rem;
    line-height: 1.8;
  }

  .post-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    color: var(--accent-deep);
    font-weight: 800;
    text-decoration: none;
  }

  .post-card-link span {
    transition: transform 0.25s ease;
  }

  .post-card-link:hover span {
    transform: translateX(2px);
  }

  @media (max-width: 768px) {
    .post-card-title {
      font-size: 1.45rem;
    }
  }
</style>
