---
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import { estimateReadingTime, formatLithuanianDate, getAllPosts } from '../../lib/content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const posts = await getAllPosts();

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { slug } = Astro.params;
const { Content } = await post.render();
const seoTitle = post.data.seoTitle || post.data.title;
const seoDescription = post.data.seoDescription || post.data.excerpt;
const socialImage = post.data.featuredImage?.src;
const readingTime = estimateReadingTime(post.body);
---

<!doctype html>
<html lang="lt">
	<head>
		<BaseHead 
			title={seoTitle} 
			description={seoDescription}
			image={socialImage}
			ogTitle={seoTitle}
			ogDescription={seoDescription}
			twitterTitle={seoTitle}
			twitterDescription={seoDescription}
		/>
	</head>
	<body>
		<Header />
		<main class="container mx-auto px-4 py-12 max-w-5xl">
			<article class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
				{post.data.featuredImage && (
					<Image
						src={post.data.featuredImage}
						alt={post.data.featuredImageAlt || post.data.title}
						class="w-full h-96 object-cover"
						widths={[720, 1024, 1440]}
						sizes="(min-width: 1024px) 1024px, 100vw"
					/>
				)}
				
				<div class="p-8 md:p-12">
					{post.data.category && (
						<div class="flex gap-2 mb-6 flex-wrap">
							<span class="text-xs font-medium bg-blue-50 text-blue-700 px-3 py-1.5 rounded uppercase tracking-wide">
								{post.data.category}
							</span>
						</div>
					)}
					
					<h1 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900 leading-tight">
						{post.data.title}
					</h1>
					
					<div class="flex items-center gap-4 text-sm text-gray-500 mb-8 pb-8 border-b border-gray-200">
						<time class="font-medium">
							{formatLithuanianDate(post.data.publishedAt)}
						</time>
						<span>•</span>
						<span>{readingTime} min skaitymo</span>
						<span>•</span>
						<span><span id="view-count">—</span> peržiūrų</span>
					</div>
					
					<script define:vars={{ slug }}>
						fetch(`https://api.counterapi.dev/v1/exemigrantai/${slug}/up`)
							.then(r => r.json())
							.then(data => {
								document.getElementById('view-count').textContent = data.count;
							})
							.catch(() => {
								document.getElementById('view-count').textContent = '0';
							});
					</script>
					
					<div class="prose prose-lg mx-auto">
						<Content />
					</div>
				</div>
			</article>
			
			<a 
				href="/" 
				class="inline-flex items-center mt-8 text-blue-600 hover:text-blue-700 font-semibold transition-colors group"
			>
				<svg class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
				</svg>
				Atgal į pradžią
			</a>
		</main>
		<Footer />
		<ScrollToTop />
	</body>
</html>
