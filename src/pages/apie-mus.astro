---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="lt">
  <head>
    <BaseHead
      title={`Apie mus - ${SITE_TITLE}`}
      description="Apie Eks Emigrantai: kam skirta svetainė, kaip rengiame praktinį turinį lietuviams tarp JK ir Lietuvos, kokiais šaltiniais remiamės ir kaip taisome klaidas."
    />
  </head>
  <body>
    <Header />
    <main class="page-shell about-shell">
      <section class="about-hero">
        <div>
          <span class="eyebrow">Apie mus</span>
          <h1 class="section-title">Eks Emigrantai</h1>
        </div>
        <p class="section-subtitle">
          Eks Emigrantai yra praktinės informacijos svetainė lietuviams, kurie gyvena,
          dirbo ar planuoja grįžti iš Jungtinės Karalystės į Lietuvą. Rašome apie dokumentus,
          mokesčius, išmokas, pensijas, keliones, muitinę ir kasdienius administracinius žingsnius.
        </p>
      </section>

      <section class="content-panel about-panel">
        <div class="about-prose">
          <p class="about-label">K&#261; darome</p>
          <h2>Padedame greičiau suprasti, nuo ko pradėti</h2>
          <p>
            Mūsų tikslas yra paprastai paaiškinti sudėtingas temas, su kuriomis susiduria
            lietuviai tarp JK ir Lietuvos: kaip susitvarkyti dokumentus, kur kreiptis, kokių
            įrodymų gali reikėti ir kokių klaidų verta išvengti.
          </p>
          <p>
            Daugiausia dėmesio skiriame praktiniams klausimams: HMRC, GOV.UK, EU Settlement
            Scheme, eVisa, P45, P60, U1, Sodra, Užimtumo tarnyba, Lietuvos muitinė, bankai ir
            kitos institucijos, su kuriomis žmonės realiai susiduria grįždami ar keliaudami.
          </p>

          <div class="surface-divider"></div>

          <p class="about-label">Kam skirta</p>
          <h2>Lietuviams tarp JK ir Lietuvos</h2>
          <p>
            Svetainė skirta žmonėms, kurie išvyko į JK, grįžo į Lietuvą, važinėja tarp
            šalių arba tvarko šeimos, darbo, mokesčių ar socialinių teisių klausimus po
            gyvenimo užsienyje.
          </p>
          <p>
            Stengiamės rašyti taip, kad tekstas būtų naudingas ne specialistui, o žmogui,
            kuris vakare atsisėdo su dokumentais ir nori suprasti, ką daryti toliau.
          </p>

          <div class="surface-divider"></div>

          <p class="about-label">Kaip rengiame turinį</p>
          <h2>Remiamės oficialiais šaltiniais ir aiškiai žymime ribas</h2>
          <p>
            Straipsniuose, kuriuose kalbama apie mokesčius, išmokas, imigracijos statusą,
            muitinę ar kitas taisykles, nurodome oficialius šaltinius ir datą, kada informacija
            buvo tikrinta. Jei tema priklauso nuo individualios situacijos, tai aiškiai pažymime.
          </p>
          <p>
            Eks Emigrantai nėra valstybinė institucija, advokatų kontora, mokesčių konsultantas
            ar oficiali konsultavimo tarnyba. Turinys skirtas padėti geriau orientuotis temoje,
            pasiruošti klausimams ir rasti teisingą oficialų kelią.
          </p>

          <div class="about-actions">
            <a href="/redakcine-politika" class="pill-link pill-link-secondary">
              Redakcinė politika
            </a>
            <a href="/kontaktai" class="pill-link pill-link-secondary">Susisiekti</a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
    <ScrollToTop />
  </body>
</html>

<style>
  .about-shell {
    padding-top: 2.4rem;
    padding-bottom: 1rem;
  }

  .about-hero {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 2rem;
    margin-bottom: 1.8rem;
  }

  .about-panel {
    padding: 1.7rem;
  }

  .about-label {
    margin: 0;
    color: var(--accent-deep);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .about-prose h2 {
    margin: 0.8rem 0 0.7rem;
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 3.1vw, 2.5rem);
    line-height: 1.06;
    letter-spacing: -0.04em;
    color: var(--surface-ink);
  }

  .about-prose p {
    color: var(--text-soft);
    line-height: 1.8;
  }

  .about-prose {
    max-width: 76ch;
  }

  .about-prose a {
    width: fit-content;
  }

  .about-prose a {
    color: var(--accent-deep);
    font-weight: 700;
    text-decoration-color: rgba(184, 100, 50, 0.35);
    text-decoration-thickness: 2px;
    text-underline-offset: 0.18em;
  }

  .about-prose .pill-link {
    margin-top: 0.3rem;
    text-decoration: none;
  }

  .about-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .about-prose .surface-divider {
    margin: 1.8rem 0;
  }

  @media (max-width: 960px) {
    .about-hero {
      align-items: start;
      flex-direction: column;
    }
  }

  @media (max-width: 720px) {
    .about-shell {
      padding-top: 1.6rem;
    }

    .about-panel {
      padding: 1.2rem;
    }
  }
</style>
