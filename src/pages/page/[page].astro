---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getAllPosts, getPaginatedPosts, getSiteSettings, POSTS_PER_PAGE } from '../../lib/content';

export async function getStaticPaths() {
  const totalPosts = (await getAllPosts()).length;
  const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE);
  const paths = [];

  for (let page = 2; page <= totalPages; page++) {
    paths.push({ params: { page: String(page) } });
  }

  return paths;
}

const { page } = Astro.params;
const currentPage = parseInt(page);

if (currentPage === 1) {
  return Astro.redirect('/');
}

const { posts, totalPages } = await getPaginatedPosts(currentPage, POSTS_PER_PAGE);
const settings = await getSiteSettings();
const homepageTitle = settings.homepageTitle || 'Naujausi įrašai';

if (posts.length === 0) {
  return Astro.redirect('/');
}
---

<!doctype html>
<html lang="lt">
  <head>
    <BaseHead title={`${SITE_TITLE} - Puslapis ${currentPage}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="page-shell archive-shell">
      <section class="archive-hero">
        <div>
          <p class="archive-kicker">Archyvas</p>
          <h1 class="section-title">{homepageTitle}</h1>
        </div>
        <p class="section-subtitle">
          Puslapis {currentPage}. Toliau rasite ankstesnius straipsnius apie dokumentus, socialinį
          draudimą, persikraustymą ir gyvenimo žingsnius grįžtant į Lietuvą.
        </p>
      </section>

      <div class="stories-grid archive-grid">
        {posts.map((post, index) => <PostCard post={post} eager={index === 0} />)}
      </div>

      {totalPages > 1 && (
        <nav class="pagination-shell" aria-label="Puslapių navigacija">
          {currentPage > 1 ? (
            <a href={currentPage === 2 ? '/' : `/page/${currentPage - 1}`} class="pagination-link">
              ← Ankstesnis
            </a>
          ) : (
            <span class="pagination-link pagination-link-muted">← Ankstesnis</span>
          )}

          <div class="pagination-pages">
            {Array.from({ length: totalPages }, (_, i) => i + 1).map((pageNumber) => (
              <a
                href={pageNumber === 1 ? '/' : `/page/${pageNumber}`}
                class={`pagination-page ${pageNumber === currentPage ? 'pagination-page-active' : ''}`}
                aria-current={pageNumber === currentPage ? 'page' : undefined}
              >
                {pageNumber}
              </a>
            ))}
          </div>

          {currentPage < totalPages ? (
            <a href={`/page/${currentPage + 1}`} class="pagination-link">
              Kitas →
            </a>
          ) : (
            <span class="pagination-link pagination-link-muted">Kitas →</span>
          )}
        </nav>
      )}
    </main>
    <Footer />
    <ScrollToTop />
  </body>
</html>

<style>
  .archive-shell {
    padding-top: 2.6rem;
    padding-bottom: 1rem;
  }

  .archive-hero {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 2rem;
    margin-bottom: 1.8rem;
  }

  .archive-kicker {
    margin: 0 0 0.5rem;
    color: var(--accent-deep);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.35rem;
  }

  .pagination-shell {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 3rem;
  }

  .pagination-pages {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.62);
    border: 1px solid var(--border);
  }

  .pagination-page,
  .pagination-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.8rem;
    padding: 0.85rem 1rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 800;
  }

  .pagination-page {
    color: var(--text-soft);
  }

  .pagination-page-active {
    background: var(--surface-ink);
    color: #fffaf4;
  }

  .pagination-link {
    color: var(--accent-deep);
  }

  .pagination-link-muted {
    color: var(--text-faint);
  }

  @media (max-width: 1024px) {
    .archive-hero {
      flex-direction: column;
      align-items: start;
    }

    .archive-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .archive-shell {
      padding-top: 1.6rem;
    }

    .archive-grid {
      grid-template-columns: 1fr;
    }

    .pagination-shell {
      flex-wrap: wrap;
    }
  }
</style>
