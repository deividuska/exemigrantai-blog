---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getAllPosts, getPaginatedPosts, getSiteSettings, POSTS_PER_PAGE } from '../../lib/content';
import '../../styles/global.css';

export async function getStaticPaths() {
	const totalPosts = (await getAllPosts()).length;
	const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE);
	const paths = [];

	for (let page = 2; page <= totalPages; page++) {
		paths.push({ params: { page: String(page) } });
	}

	return paths;
}

const { page } = Astro.params;
const currentPage = parseInt(page);

if (currentPage === 1) {
	return Astro.redirect('/');
}

const { posts, totalPages } = await getPaginatedPosts(currentPage, POSTS_PER_PAGE);
const settings = await getSiteSettings();
const homepageTitle = settings.homepageTitle || 'Naujausi įrašai';

if (posts.length === 0) {
	return Astro.redirect('/');
}
---

<!doctype html>
<html lang="lt">
	<head>
		<BaseHead title={`${SITE_TITLE} - Puslapis ${currentPage}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="container mx-auto px-4 py-16 max-w-6xl">
			<h1 class="text-3xl font-bold text-center mb-12 text-gray-900">{homepageTitle}</h1>
			
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{posts.map((post, index) => <PostCard post={post} eager={index === 0} />)}
			</div>

			{totalPages > 1 && (
				<nav class="flex justify-center items-center gap-2 mt-12" aria-label="Puslapių navigacija">
					{currentPage > 1 && (
						<a 
							href={currentPage === 2 ? '/' : `/page/${currentPage - 1}`} 
							class="px-4 py-2 text-blue-600 hover:text-blue-700 font-medium transition-colors"
						>
							← Ankstesnis
						</a>
					)}

					{Array.from({ length: totalPages }, (_, i) => i + 1).map((pageNumber) => (
						<a
							href={pageNumber === 1 ? '/' : `/page/${pageNumber}`}
							class={`px-4 py-2 rounded-lg font-medium transition-colors ${
								pageNumber === currentPage
									? 'bg-blue-600 text-white'
									: 'bg-white text-gray-700 hover:bg-gray-100 border border-gray-200'
							}`}
							aria-current={pageNumber === currentPage ? 'page' : undefined}
						>
							{pageNumber}
						</a>
					))}

					{currentPage < totalPages && (
						<a 
							href={`/page/${currentPage + 1}`} 
							class="px-4 py-2 text-blue-600 hover:text-blue-700 font-medium transition-colors"
						>
							Kitas →
						</a>
					)}
				</nav>
			)}
		</main>
		<Footer />
		<ScrollToTop />
	</body>
</html>
